<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Storitad — Stats</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="stylesheet" href="style.css">
  </head>
  <body>
    <header>
      <h1>Stats</h1>
      <nav class="nav">
        <a href="index.html">Entries</a>
        <a href="stats.html" class="current">Stats</a>
      </nav>
    </header>
    <main>
      {% if totals.count == 0 %}
        <p class="empty">No entries yet.</p>
      {% else %}
        <div class="stats-grid">
          <div class="stat"><div class="k">Total</div><div class="v">{{ totals.count }}</div></div>
          <div class="stat"><div class="k">Voice</div><div class="v">{{ totals.voice }}</div></div>
          <div class="stat"><div class="k">Video</div><div class="v">{{ totals.video }}</div></div>
          <div class="stat"><div class="k">Total time</div><div class="v">{{ totals.total_duration }}</div></div>
          <div class="stat"><div class="k">Average</div><div class="v">{{ totals.avg_duration }}</div></div>
          <div class="stat"><div class="k">Longest</div><div class="v">{{ totals.longest_duration }}</div></div>
          <div class="stat"><div class="k">Shortest</div><div class="v">{{ totals.shortest_duration }}</div></div>
        </div>

        <h2>Entries per month</h2>
        <div class="timeline">
          {% set peak = months|map(attribute='total')|max %}
          <div class="bars">
            {% for b in months %}
              <div class="bar-col" title="{{ b.label }}: {{ b.voice }} voice, {{ b.video }} video">
                <div class="bar-count">{% if b.total > 0 %}{{ b.total }}{% endif %}</div>
                <div class="bar-stack">
                  {% if b.video > 0 %}
                    <div class="bar bar-video" style="height: {{ (100 * b.video / peak)|round(2) }}%"></div>
                  {% endif %}
                  {% if b.voice > 0 %}
                    <div class="bar bar-voice" style="height: {{ (100 * b.voice / peak)|round(2) }}%"></div>
                  {% endif %}
                </div>
                <div class="bar-label">{{ b.label }}</div>
              </div>
            {% endfor %}
          </div>
          <div class="legend">
            <span><span class="sw" style="background:var(--primary)"></span>Voice</span>
            <span><span class="sw" style="background:var(--muted);opacity:.6"></span>Video</span>
          </div>
        </div>

        {% if recipients %}
        <h2>Recipients</h2>
        <div class="kv-list">
          {% for name, count in recipients %}
            <div class="k">{{ name }}</div><div class="v">{{ count }}</div>
          {% endfor %}
        </div>
        {% endif %}

        {% if tags %}
        <h2>Top tags</h2>
        <div class="kv-list">
          {% for tag, count in tags %}
            <div class="k">#{{ tag }}</div><div class="v">{{ count }}</div>
          {% endfor %}
        </div>
        {% endif %}
      {% endif %}
    </main>
  </body>
</html>
